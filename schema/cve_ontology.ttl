cve:CveRecord rdfs:subClassOf [ a owl:Restriction ; owl:onProperty cve:requester ; owl:maxCardinality 1 ] .
cve:CveRecord rdfs:subClassOf [ a owl:Restriction ; owl:onProperty cve:sourceSchema ; owl:maxCardinality 1 ] .
